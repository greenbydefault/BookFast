    { "source": "/dashboard/(.*)", "destination": "/app-shell.html" },
    { "source": "/b", "destination": "/app-shell.html" },
    { "source": "/b/(.*)", "destination": "/app-shell.html" },
    { "source": "/embed.js", "destination": "/embed.js" },
    { "source": "/login.html", "destination": "/login.html" },
    { "source": "/register.html", "destination": "/register.html" },
    { "source": "/forgot-password.html", "destination": "/forgot-password.html" },
    { "source": "/update-password.html", "destination": "/update-password.html" },
    { "source": "/private-policies.html", "destination": "/private-policies.html" },
